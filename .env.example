# Supabase — consumed only through packages/db/client.ts
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=xxxx

# Mobile app (Expo) — same values, EXPO_PUBLIC_ prefix so they are inlined into the bundle
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=xxxx

# Prisma (schema/migrations only — from Supabase → Project Settings → Database)
# Pooled connection (pgBouncer, port 6543) used as the default datasource.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:6543/postgres?pgbouncer=true
# Direct connection (port 5432) used by `prisma migrate`.
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
