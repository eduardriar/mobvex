{
  "expo": {
    "name": "Mobvex",
    "slug": "mobvex",
    "scheme": "mobvex",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0B",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobvex.app"
    },
    "android": {
      "package": "com.mobvex.app",
      "edgeToEdgeEnabled": true,
      "backgroundColor": "#0A0A0B",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#C8FF00"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Mobvex usa tus fotos para registrar tu progreso corporal.",
          "cameraPermission": "Mobvex usa la cámara para tomar fotos de tu progreso corporal."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
