// Mobvex — Prisma schema
//
// Used as a SCHEMA/MIGRATION tool only. The app queries through supabase-js at
// runtime (see packages/db/client.ts); Prisma is just how the Postgres tables
// are defined and migrated.
//
// Conventions:
//   - Tables and columns are snake_case (via @map / @@map) to match Supabase's
//     generated types and packages/db/types.ts.
//   - `id` is a uuid. `users.id` is expected to match Supabase Auth's
//     auth.users.id — keep them in sync when creating profiles.
//
// NOTE: Prisma Migrate does NOT manage Row Level Security. The project requires
// RLS on every table (trainers see only their students/routines; students see
// only their own data). Add RLS policies in a separate Supabase SQL migration
// after running `prisma migrate`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase pgBouncer) for the app/runtime.
  url       = env("DATABASE_URL")
  // Direct connection for migrations (Supabase "Direct connection" string).
  directUrl = env("DIRECT_URL")
}

enum Role {
  trainer
  student
}

enum Goal {
  muscle_gain
  fat_loss
  performance
  general_health
  hypertrophy
  force
  maintenance
}

enum SessionStatus {
  active
  completed
  abandoned
}

enum PhotoPose {
  front
  left
  right
  back
}

/// Base user — a trainer or a student. Extends Supabase Auth (auth.users).
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  role      Role
  name      String
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // A trainer has many students; a student-user has one student profile.
  studentsAsTrainer  Student[]   @relation("TrainerStudents")
  studentProfile     Student?    @relation("StudentUser")
  routinesAsTrainer  Routine[]   @relation("TrainerRoutines")
  nutritionAsTrainer Nutrition[] @relation("TrainerNutrition")
  exercisesAsTrainer Exercise[]  @relation("TrainerExercises")
  recipesAsTrainer   Recipe[]    @relation("TrainerRecipes")

  @@map("users")
}

/// A student linked to a trainer.
model Student {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainerId   String   @map("trainer_id") @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  goal        Goal
  active      Boolean  @default(true)
  inviteToken String   @unique @default(dbgenerated("gen_random_uuid()")) @map("invite_token") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  trainer         User             @relation("TrainerStudents", fields: [trainerId], references: [id], onDelete: Cascade)
  user            User             @relation("StudentUser", fields: [userId], references: [id], onDelete: Cascade)
  routines        Routine[]
  progress        Progress[]
  nutrition       Nutrition[]
  workoutSessions WorkoutSession[]

  @@index([trainerId])
  @@map("students")
}

/// A routine assigned to a student.
model Routine {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  trainerId   String   @map("trainer_id") @db.Uuid
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  student          Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  trainer          User              @relation("TrainerRoutines", fields: [trainerId], references: [id], onDelete: Cascade)
  routineExercises RoutineExercise[]
  workoutSessions  WorkoutSession[]

  @@index([studentId])
  @@index([trainerId])
  @@map("routines")
}

/// A reusable exercise in the catalog. Defines only what the exercise *is*
/// (name, target muscle, demo video) — never how it is prescribed. Prescription
/// (sets/reps/rest/order) lives on RoutineExercise.
///
/// `trainerId` makes ownership hybrid: NULL rows are the shared global catalog
/// (seeded), while a set `trainerId` is a private exercise owned by one trainer.
model Exercise {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainerId   String?  @map("trainer_id") @db.Uuid
  name        String
  muscleGroup String?  @map("muscle_group")
  videoUrl    String?  @map("video_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  trainer          User?             @relation("TrainerExercises", fields: [trainerId], references: [id], onDelete: Cascade)
  routineExercises RoutineExercise[]

  @@index([trainerId])
  @@map("exercises")
}

/// Places a catalog Exercise into a Routine with the prescription for that
/// routine. The same Exercise can appear in many routines, each with its own
/// sets/reps/rest/order. Deleting a routine cascades these rows; an exercise
/// still referenced here cannot be deleted (onDelete: Restrict).
model RoutineExercise {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routineId   String  @map("routine_id") @db.Uuid
  exerciseId  String  @map("exercise_id") @db.Uuid
  order       Int
  sets        Int
  reps        String
  restSeconds Int     @map("rest_seconds")
  notes       String?

  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  setLogs  SetLog[]

  @@unique([routineId, order])
  @@index([routineId])
  @@index([exerciseId])
  @@map("routine_exercises")
}

/// One instance of a student performing a routine. Status `active` is the
/// student's current workout; only one active session per student is allowed
/// (enforced by a partial unique index added in the migration). Completed and
/// abandoned sessions are retained as training history.
model WorkoutSession {
  // gen_random_uuid() is a DB-level default so inserts via supabase-js (which
  // bypass Prisma's client-side @default(uuid())) get an id.
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId   String        @map("student_id") @db.Uuid
  routineId   String        @map("routine_id") @db.Uuid
  status      SessionStatus @default(active)
  startedAt   DateTime      @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?     @map("completed_at") @db.Timestamptz(6)
  notes       String?

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  routine Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  setLogs SetLog[]

  @@index([studentId])
  @@index([routineId])
  @@map("workout_sessions")
}

/// One logged set within a workout session: the actual weight, reps and effort
/// (RIR — reps in reserve) the student performed for a prescribed exercise.
/// Sets are pre-created from the routine's prescription when a session starts.
model SetLog {
  // DB-level default so supabase-js inserts get an id (see WorkoutSession).
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId         String   @map("session_id") @db.Uuid
  routineExerciseId String   @map("routine_exercise_id") @db.Uuid
  setNumber         Int      @map("set_number")
  weightKg          Float?   @map("weight_kg")
  reps              Int?
  rir               Int?
  completed         Boolean  @default(false)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  session         WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  routineExercise RoutineExercise @relation(fields: [routineExerciseId], references: [id], onDelete: Cascade)

  @@unique([sessionId, routineExerciseId, setNumber])
  @@index([sessionId])
  @@index([routineExerciseId])
  @@map("set_logs")
}

/// A student progress record for a given day.
model Progress {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId        String   @map("student_id") @db.Uuid
  date             DateTime @db.Date
  weightKg         Float?   @map("weight_kg")
  bodyFatPct       Float?   @map("body_fat_pct")
  // Body measurements in centimeters.
  chestCm          Float?   @map("chest_cm")
  armCm            Float?   @map("arm_cm")
  waistCm          Float?   @map("waist_cm")
  shoulderCm       Float?   @map("shoulder_cm")
  quadsCm          Float?   @map("quads_cm")
  calfCm           Float?   @map("calf_cm")
  glutesCm         Float?   @map("glutes_cm")
  photoUrl         String?  @map("photo_url")
  targetCalories   Int?     @map("target_calories")
  achievedCalories Int?     @map("achieved_calories")
  notes            String?

  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  photos  ProgressPhoto[]

  // One progress record per student per day — saveProgress upserts on this key.
  @@unique([studentId, date])
  @@index([studentId])
  @@map("progress")
}

/// A progress photo for one pose, attached to a day's Progress record. The image
/// file lives in the `progress-photos` Storage bucket at `storagePath`. At most
/// four per progress entry — one per pose (enforced by the unique index).
model ProgressPhoto {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  progressId  String    @map("progress_id") @db.Uuid
  pose        PhotoPose
  storagePath String    @map("storage_path")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  progress Progress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([progressId, pose])
  @@index([progressId])
  @@map("progress_photos")
}

/// A nutrition / diet plan assigned by a trainer to a student.
model Nutrition {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId   String  @map("student_id") @db.Uuid
  trainerId   String  @map("trainer_id") @db.Uuid
  name        String
  description String?

  /// Daily targets the student should hit on this plan.
  targetCalories Int? @map("target_calories")
  proteinG       Int? @map("protein_g")
  carbsG         Int? @map("carbs_g")
  fatG           Int? @map("fat_g")
  waterMl        Int? @map("water_ml")

  /// Optional validity window for the plan.
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date

  /// Only one plan is typically active per student at a time.
  active    Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  trainer User    @relation("TrainerNutrition", fields: [trainerId], references: [id], onDelete: Cascade)
  meals   Meal[]

  @@index([studentId])
  @@index([trainerId])
  @@map("nutrition")
}

/// A reusable recipe = a meal option (e.g. "Pollo y arroz", 720 kcal). Hybrid
/// ownership like Exercise: NULL trainerId is the shared catalog; a set trainerId
/// is a trainer's private recipe.
model Recipe {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainerId String?  @map("trainer_id") @db.Uuid
  name      String
  kcal      Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  trainer         User?        @relation("TrainerRecipes", fields: [trainerId], references: [id], onDelete: Cascade)
  recipeItems     RecipeItem[]
  mealRecipes     MealRecipe[]
  selectedInMeals Meal[]       @relation("SelectedRecipe")

  @@index([trainerId])
  @@map("recipes")
}

/// A food line within a recipe (e.g. "Pechuga de pollo" · "200 g").
model RecipeItem {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipeId String @map("recipe_id") @db.Uuid
  food     String
  qty      String
  order    Int

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, order])
  @@index([recipeId])
  @@map("recipe_items")
}

/// A meal slot within a nutrition plan (e.g. Desayuno @ 07:30). Offers several
/// equivalent recipe options; the student picks one (selectedRecipeId, null ⇒
/// the first option by order).
model Meal {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nutritionId      String  @map("nutrition_id") @db.Uuid
  name             String
  time             String
  icon             String
  hue              String
  order            Int
  selectedRecipeId String? @map("selected_recipe_id") @db.Uuid

  nutrition      Nutrition    @relation(fields: [nutritionId], references: [id], onDelete: Cascade)
  selectedRecipe Recipe?      @relation("SelectedRecipe", fields: [selectedRecipeId], references: [id], onDelete: SetNull)
  mealRecipes    MealRecipe[]

  @@unique([nutritionId, order])
  @@index([nutritionId])
  @@map("meals")
}

/// Join: the recipe options available for a meal (the trainer's equivalents).
model MealRecipe {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mealId   String @map("meal_id") @db.Uuid
  recipeId String @map("recipe_id") @db.Uuid
  order    Int

  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Restrict)

  @@unique([mealId, recipeId])
  @@unique([mealId, order])
  @@index([mealId])
  @@index([recipeId])
  @@map("meal_recipes")
}
